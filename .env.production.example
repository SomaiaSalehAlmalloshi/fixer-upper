# Production runtime env for self-hosted deployment. Copy to .env.production
# and fill in real values. Do NOT commit .env.production.
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# --- Public (safe to expose to browser) ---
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_ID

# --- Server-only (never sent to the browser) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
LOVABLE_API_KEY=YOUR_LOVABLE_AI_GATEWAY_KEY

# --- Backups (only when running the "backup" profile) ---
DATABASE_URL=postgres://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres
BACKUP_RETAIN_DAYS=14
# S3_BUCKET=risk-platform-backups
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=eu-west-1
